{
  "manifest_version": 3,
  "name": "Blue & Red AI Agent",
  "version": "1.0.0",
  "description": "Autonomous web navigation and action agent powered by Mistral AI.",
  "permissions": ["activeTab", "scripting", "storage", "cookies", "webNavigation", "webRequest"],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": ["<all_urls>"]
}
